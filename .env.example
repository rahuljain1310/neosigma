# PostgreSQL (docker-compose maps container 5432 -> host 5433)
DATABASE_URL=postgresql+asyncpg://agentopt:agentopt@localhost:5433/agentopt

# LLM key for the optimizer and (in harbor mode) the agent under test.
OPENAI_API_KEY=

# Sandbox provider credential, only needed when executor=harbor with env_provider=e2b
E2B_API_KEY=

# auto|llm|heuristic — auto picks llm when OPENAI_API_KEY is set, else heuristic
OPTIMIZER_MODE=auto
OPTIMIZER_MODEL=gpt-5.4
AGENT_MODEL=gpt-5.4
