# PostgreSQL (docker-compose maps container 5432 -> host 5433)
DATABASE_URL=postgresql+asyncpg://agentopt:agentopt@localhost:5433/agentopt

# JWT auth (change JWT_SECRET in production)
JWT_SECRET=dev-secret-change-in-production

OPENAI_API_KEY=

# Harbor sandbox backend:
#   docker  — needs host Docker socket (mounted in compose). Terminal-Bench images are
#             linux/amd64; on Apple Silicon they often fail unless Colima/Docker runs
#             with amd64/qemu. Prefer daytona or e2b on arm64 Macs.
#   daytona — cloud sandboxes via Harbor --env daytona (requires DAYTONA_API_KEY)
#   e2b     — cloud sandboxes (requires E2B_API_KEY)
HARBOR_ENV_PROVIDER=daytona

# Cloud sandbox credentials (set the one matching HARBOR_ENV_PROVIDER)
DAYTONA_API_KEY=
E2B_API_KEY=
# auto|llm|heuristic — auto picks llm when OPENAI_API_KEY is set, else heuristic
OPTIMIZER_MODE=auto
OPTIMIZER_MODEL=gpt-5.4
AGENT_MODEL=gpt-5.4
